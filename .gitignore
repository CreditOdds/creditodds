# Dependencies
node_modules/

# Build outputs
dist/
build/
.build/
.aws-sam/
apps/api/packaged.yaml
data/news.json
# Generated by `npm run build:cards` from data/cards/*.yaml. Never commit: the
# committed copy silently drifts from the YAML (it was ~5 weeks stale, rendering
# wrong SUBs in dev). Prod reads it from the CDN/API; it's regenerated at build
# time (Amplify preBuild) and dev start (web-next predev).
data/cards.json

# Environment files
.env
.env.local
.env.*.local

# SAM config (contains deployment parameters)
samconfig.toml

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Test coverage
coverage/

# Temporary files
*.tmp
*.temp

# Workflow artifacts
.apply-link-check-result.json
.issue-body.md
.card-page-check-summary.md
.card-page-check-stale.md
# NB: .github/card-page-check-state.json is deliberately NOT ignored — the
# consecutive-skip counters only work if they persist across runs.

# Claude Code local settings
.claude/

# Firebase service account keys (never commit these!)
*-firebase-adminsdk-*.json
serviceAccountKey.json
